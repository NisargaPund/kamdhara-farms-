# ============================================================
# KAMDHARA FARMS — Environment Variables
# Copy this file to .env and fill in YOUR values
# ============================================================

# --- STEP 1: Create free account at https://supabase.com ---
# Create new project → wait 2 minutes → go to Settings → API

VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- STEP 2: Razorpay (https://dashboard.razorpay.com/app/keys) ---

VITE_RAZORPAY_KEY_ID=rzp_test_T50Gvk4WQ1C4sm

# --- Required on Netlify (Site settings → Environment variables) ---
# Vite bakes these into the build — set them BEFORE deploying.
# VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here
# VITE_RAZORPAY_KEY_ID=rzp_test_T50Gvk4WQ1C4sm

# --- Production site URL (auth email links + order tracking) ---
# Set on Netlify AND in Supabase → Authentication → URL Configuration:
#   Site URL = your Netlify/custom domain
#   Redirect URLs = https://YOUR-SITE.netlify.app/login (and custom domain /login)
# VITE_SITE_URL=https://YOUR-SITE.netlify.app

# ============================================================
# AFTER DEPLOY — Supabase SQL Editor (fixes signup + images)
# Paste and run: supabase/run_on_production.sql
# ============================================================

# ============================================================
# SUPABASE EDGE FUNCTION SECRETS (Dashboard only — NOT in .env)
# Supabase → Project Settings → Edge Functions → Secrets
# ============================================================
#
# Required for checkout:
#   RAZORPAY_KEY_ID = rzp_test_T50Gvk4WQ1C4sm
#   RAZORPAY_KEY_SECRET = your_secret_key
#
# Optional — order email notifications (Resend):
#   RESEND_API_KEY = re_...
#   RESEND_FROM_EMAIL = orders@kamdharafarms.com
#
# Optional — order WhatsApp notifications (Twilio):
#   TWILIO_ACCOUNT_SID = AC...
#   TWILIO_AUTH_TOKEN = ...
#   TWILIO_WHATSAPP_FROM = whatsapp:+14155238886
#
# Optional — links in notification emails/messages:
#   SITE_URL = https://kamdharafarms.com
