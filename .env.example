# ============================================================
# KAMDHARA FARMS — Environment Variables
# Copy this file to .env and fill in YOUR values
# ============================================================

# --- STEP 1: Create free account at https://supabase.com ---
# Create new project → wait 2 minutes → go to Settings → API

VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- STEP 2: Razorpay (https://dashboard.razorpay.com/app/keys) ---

VITE_RAZORPAY_KEY_ID=rzp_test_T50Gvk4WQ1C4sm

# --- Optional: production site URL (for order tracking links) ---
# VITE_SITE_URL=https://kamdharafarms.com

# ============================================================
# SUPABASE EDGE FUNCTION SECRETS (Dashboard only — NOT in .env)
# Supabase → Project Settings → Edge Functions → Secrets
# ============================================================
#
# Required for checkout:
#   RAZORPAY_KEY_ID = rzp_test_T50Gvk4WQ1C4sm
#   RAZORPAY_KEY_SECRET = your_secret_key
#
# Optional — order email notifications (Resend):
#   RESEND_API_KEY = re_...
#   RESEND_FROM_EMAIL = orders@kamdharafarms.com
#
# Optional — order WhatsApp notifications (Twilio):
#   TWILIO_ACCOUNT_SID = AC...
#   TWILIO_AUTH_TOKEN = ...
#   TWILIO_WHATSAPP_FROM = whatsapp:+14155238886
#
# Optional — links in notification emails/messages:
#   SITE_URL = https://kamdharafarms.com
